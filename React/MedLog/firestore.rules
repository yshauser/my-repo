rules_version = '2';

// Firebase Auth is now required for all access.
// Google users are authenticated via Firebase Auth (request.auth != null).
// Test users (username-only login) bypass Firebase Auth — they are only
// usable in development; in production all users should have Google sign-in.
// TODO: Add per-family scoping rules as a future improvement.

service cloud.firestore {
  match /databases/{database}/documents {

    // Medicine reference data — public read (needed at app startup before login), auth required to write
    match /medicines/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /metadata/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Operational collections — require Firebase Auth session
    match /kids/{docId} {
      allow read, write: if request.auth != null;
    }

    match /logs/{docId} {
      allow read, write: if request.auth != null;
    }

    match /tasks/{docId} {
      allow read, write: if request.auth != null;
    }

    match /users/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /families/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}